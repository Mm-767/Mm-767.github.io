---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts, getAllTags } from '../lib/posts';
import { Rss } from '@lucide/astro';

// Edit the copy below freely — this is a plain page, not a Markdown post.
const posts = await getAllPosts();
const tags = await getAllTags();
const postCount = posts.length;
---
<BaseLayout title="About" description="GIT.B — 백엔드 스터디와 개발 기록을 남기는 git 기반 블로그">
  <section class="mx-auto max-w-[680px] px-4 pb-20 pt-14">
    <h1 class="text-[40px] font-semibold leading-[1.1] tracking-[-1px] text-pin-plum">About</h1>
    <p class="mt-4 text-body leading-[1.6] text-pin-olive">
      백엔드 공부와 개발하면서 부딪힌 것들을 기록하는 블로그예요.
      스터디 노트, 미션 제출본, 코드 리뷰 후기까지 — 그때그때 정리한 글을 모아둡니다.
    </p>
    <p class="mt-4 text-body leading-[1.6] text-pin-olive">
      글은 전부 Markdown으로 쓰고 GitHub 저장소에 커밋하면 GitHub Pages로 자동 배포돼요.
      DB도 CMS도 없이 <code class="rounded bg-pin-warm-light px-1.5 py-0.5 text-caption">.md</code> 파일 하나가
      글 하나인 구조라, 글의 원본이 곧 git 히스토리로 남습니다.
    </p>

    <div class="mt-8 flex flex-wrap gap-6 border-y border-pin-warm-light py-5">
      <div>
        <div class="text-[28px] font-bold tracking-[-0.6px] text-pin-plum">{postCount}</div>
        <div class="text-caption text-pin-silver">Posts</div>
      </div>
      <div>
        <div class="text-[28px] font-bold tracking-[-0.6px] text-pin-plum">{tags.length}</div>
        <div class="text-caption text-pin-silver">Tags</div>
      </div>
    </div>

    {tags.length > 0 && (
      <div class="mt-6">
        <p class="mb-2 text-caption-bold text-pin-silver">주로 쓰는 주제</p>
        <div class="flex flex-wrap gap-2">
          {tags.map((t) => (
            <a href={'/tags/' + t.slug} class="rounded-full bg-pin-warm-light px-3 py-1.5 text-caption-bold text-pin-plum hover:bg-pin-hover-gray">
              {t.name} <span class="text-pin-silver">{t.count}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="https://github.com/Mm-767" class="inline-flex items-center gap-1.5 rounded-pin bg-pin-plum px-4 py-2 text-caption-bold text-white hover:bg-pin-dark">
        GitHub
      </a>
      <a href="/rss.xml" class="inline-flex items-center gap-1.5 rounded-pin bg-pin-sand px-4 py-2 text-caption-bold text-pin-plum hover:text-pin-red">
        <Rss size={15} /> RSS 구독
      </a>
    </div>
  </section>
</BaseLayout>
