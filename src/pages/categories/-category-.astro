---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasonryGrid from '../../components/MasonryGrid.astro';
import PinCard from '../../components/PinCard.astro';
import { getAllPosts, getAllCategories, slugify } from '../../lib/posts';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  const posts = await getAllPosts();
  return categories.map((category) => ({
    params: { category: category.slug },
    props: {
      category,
      posts: posts.filter((p) => slugify(p.data.category) === category.slug),
    },
  }));
}
const { category, posts } = Astro.props;
---
<BaseLayout title={category.name}>
  <section class="mx-auto max-w-[1440px] px-4 py-10">
    <p class="text-caption-bold text-pin-olive"><a href="/" class="hover:text-pin-red">Home</a> / {category.name}</p>
    <h1 class="mt-1 text-heading text-pin-plum">{category.name} <span class="font-normal text-pin-olive">({posts.length})</span></h1>
    <div class="mt-6">
      <MasonryGrid>
        {posts.map((post) => <PinCard post={post} />)}
      </MasonryGrid>
    </div>
  </section>
</BaseLayout>
