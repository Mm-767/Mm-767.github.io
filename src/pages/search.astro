---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search">
  <section class="mx-auto max-w-[720px] px-4 pt-12">
    <h1 class="text-heading text-pin-plum">Search</h1>
    <input
      id="search-input"
      type="search"
      placeholder="Search by title or date"
      class="mt-4 w-full rounded-pin border border-pin-silver bg-white px-[15px] py-[11px] text-body text-pin-plum outline-none placeholder:text-pin-silver focus:ring-2 focus:ring-pin-focus"
    />
    <p id="search-empty" class="mt-6 hidden text-body text-pin-olive"></p>
  </section>
  <section class="mx-auto max-w-[1440px] px-4 pb-8 pt-8">
    <div id="search-results" class="columns-1 gap-4 sm:columns-2 lg:columns-3 xl:columns-4"></div>
  </section>

  <script is:inline>
    (function () {
      function card(p) {
        var wrap = document.createElement('article');
        wrap.className = 'mb-4 break-inside-avoid';
        var box = document.createElement('div');
        box.className = 'overflow-hidden rounded-pin-lg bg-white';
        var a = document.createElement('a');
        a.href = '/posts/' + p.slug;
        a.className = 'block';
        if (p.thumbnail) {
          var img = document.createElement('img');
          img.src = p.thumbnail;
          img.alt = p.title;
          img.loading = 'lazy';
          img.className = 'w-full';
          a.appendChild(img);
        }
        var body = document.createElement('div');
        body.className = 'flex flex-col gap-1 px-4 pb-4 pt-3';
        var meta = document.createElement('p');
        meta.className = 'text-caption text-pin-olive';
        meta.textContent = p.category;
        var h = document.createElement('h2');
        h.className = 'text-caption-bold leading-snug text-pin-plum';
        h.textContent = p.title;
        body.appendChild(meta);
        body.appendChild(h);
        a.appendChild(body);
        box.appendChild(a);
        wrap.appendChild(box);
        return wrap;
      }

      fetch('/search.json')
        .then(function (res) { return res.json(); })
        .then(function (posts) {
          var input = document.getElementById('search-input');
          var results = document.getElementById('search-results');
          var empty = document.getElementById('search-empty');

          function run() {
            var q = input.value.trim().toLowerCase();
            var list = !q
              ? posts
              : posts.filter(function (p) {
                  return (
                    p.title.toLowerCase().indexOf(q) !== -1 ||
                    p.date.indexOf(q) !== -1 ||
                    p.dateLabel.toLowerCase().indexOf(q) !== -1
                  );
                });
            results.innerHTML = '';
            if (q && list.length === 0) {
              empty.textContent = 'No results for "' + input.value.trim() + '". Try different keywords.';
              empty.classList.remove('hidden');
            } else {
              empty.classList.add('hidden');
              list.forEach(function (p) { results.appendChild(card(p)); });
            }
          }

          var params = new URLSearchParams(location.search);
          if (params.get('q')) input.value = params.get('q');
          input.addEventListener('input', run);
          run();
        });
    })();
  </script>
</BaseLayout>
