---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasonryGrid from '../../components/MasonryGrid.astro';
import PinCard from '../../components/PinCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getAllPosts, formatDate, readingTime } from '../../lib/posts';
import { render } from 'astro:content';
import { ArrowLeft, Pencil, Trash2 } from '@lucide/astro';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// ToC: only h2/h3 so the sidebar stays scannable on long dev posts.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const minutes = readingTime(post.body ?? '');

const allPosts = await getAllPosts();
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
  .slice(0, 3);

// Chronological prev/next across all posts (allPosts is newest-first).
const idx = allPosts.findIndex((p) => p.id === post.id);
const newerPost = idx > 0 ? allPosts[idx - 1] : null;              // more recent
const olderPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null; // earlier

// Series: sibling posts sharing this post's `series`, in reading order (oldest
// first), with the current post's position highlighted.
const seriesPosts = post.data.series
  ? allPosts
      .filter((p) => p.data.series === post.data.series)
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  : [];
const seriesIndex = seriesPosts.findIndex((p) => p.id === post.id);
---
<BaseLayout title={post.data.title} description={post.data.description} image={post.data.thumbnail} type="article">
  <article class="post-article mx-auto max-w-[1080px] px-4 pb-20 pt-10">
    <a href="/" class="mb-6 inline-flex items-center gap-1.5 text-caption-bold text-pin-olive hover:text-pin-red">
      <ArrowLeft size={16} /> Back to Grid
    </a>

    {post.data.thumbnail ? (
      <img
        src={post.data.thumbnail}
        alt={post.data.title}
        class="mb-8 w-full rounded-pin-hero object-cover"
        style="max-height:560px"
      />
    ) : (
      <div class="mb-8 flex h-[280px] w-full items-center justify-center rounded-pin-hero bg-pin-warm-light">
        <span class="font-mono text-caption text-pin-silver">cover image</span>
      </div>
    )}

    <header class="mb-10 flex flex-col gap-4">
      <h1 class="text-[36px] font-semibold leading-[1.15] tracking-[-0.8px] text-pin-plum sm:text-[44px]">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-2 text-caption text-pin-olive">
        <span>{formatDate(post.data.date)}</span>
        <span class="text-pin-silver">·</span>
        <span>{minutes}분 읽기</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      )}
      <div class="mt-2 flex gap-2.5">
        <a href="/" class="inline-flex items-center gap-1.5 rounded-pin bg-pin-sand px-4 py-2 text-caption-bold text-pin-plum hover:text-pin-red">
          <ArrowLeft size={14} /> Back
        </a>
        <a href={'/new?edit=' + post.id} class="inline-flex items-center gap-1.5 rounded-pin bg-pin-plum px-4 py-2 text-caption-bold text-white hover:bg-pin-dark">
          <Pencil size={14} /> Edit Post
        </a>
        <button id="delete-post-btn" type="button" data-slug={post.id} data-title={post.data.title}
          class="inline-flex items-center gap-1.5 rounded-pin bg-pin-sand px-4 py-2 text-caption-bold text-pin-red hover:bg-pin-red hover:text-white">
          <Trash2 size={14} /> Delete
        </button>
      </div>
    </header>

    {seriesPosts.length > 1 && (
      <section class="mb-10 rounded-pin-lg border border-pin-warm-light bg-pin-fog p-5">
        <p class="text-caption-bold text-pin-silver">
          시리즈 · {post.data.series} <span class="text-pin-olive">({seriesIndex + 1}/{seriesPosts.length})</span>
        </p>
        <ol class="mt-3 flex flex-col gap-1.5">
          {seriesPosts.map((p, i) => (
            <li class="flex items-baseline gap-2 text-caption">
              <span class="w-5 shrink-0 text-right text-pin-silver">{i + 1}.</span>
              {p.id === post.id ? (
                <span class="font-bold text-pin-plum">{p.data.title}</span>
              ) : (
                <a href={'/posts/' + p.id} class="text-pin-link hover:text-pin-red">{p.data.title}</a>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    <div class="relative">
      {toc.length > 0 && (
        <aside class="absolute inset-y-0 left-[-44px] hidden w-[168px] xl:block">
          <nav class="post-toc sticky top-24 flex max-h-[calc(100vh-8rem)] flex-col gap-2 overflow-y-auto border-l border-pin-warm-light pl-3">
            <p class="mb-1 text-caption-bold text-pin-silver">On this page</p>
            {toc.map((h) => (
              <a
                href={'#' + h.slug}
                class:list={['text-caption text-pin-olive hover:text-pin-red', h.depth === 3 && 'pl-3']}
                data-toc-link={h.slug}
              >{h.text}</a>
            ))}
          </nav>
        </aside>
      )}

      <div
        class="prose prose-slate mx-auto max-w-[680px] text-body text-pin-plum
          prose-headings:font-sans prose-headings:font-bold prose-headings:tracking-[-0.4px] prose-headings:text-pin-plum
          prose-h2:mt-10 prose-h2:text-[24px] prose-h3:mt-8 prose-h3:text-[19px]
          prose-p:leading-[1.5] prose-a:text-pin-link prose-a:no-underline hover:prose-a:text-pin-red
          prose-strong:text-pin-plum prose-code:before:content-none prose-code:after:content-none
          prose-img:rounded-pin-lg prose-blockquote:border-pin-red prose-blockquote:text-pin-olive"
      >
        {Content ? <Content /> : <p class="text-pin-olive">This post has no body content.</p>}
      </div>
    </div>

    {related.length > 0 && (
      <section class="mt-20 border-t border-pin-warm-light pt-10">
        <h2 class="mb-5 text-[22px] font-bold tracking-[-0.4px] text-pin-plum">More from this tag</h2>
        <MasonryGrid>
          {related.map((p) => <PinCard post={p} />)}
        </MasonryGrid>
      </section>
    )}

    {(olderPost || newerPost) && (
      <nav class="mt-16 grid gap-3 border-t border-pin-warm-light pt-8 sm:grid-cols-2">
        {olderPost ? (
          <a href={'/posts/' + olderPost.id} class="group rounded-pin-lg border border-pin-warm-light p-4 hover:border-pin-red">
            <span class="text-caption text-pin-silver">← 이전 글</span>
            <p class="mt-1 text-caption-bold leading-snug text-pin-plum group-hover:text-pin-red">{olderPost.data.title}</p>
          </a>
        ) : <span></span>}
        {newerPost ? (
          <a href={'/posts/' + newerPost.id} class="group rounded-pin-lg border border-pin-warm-light p-4 text-right hover:border-pin-red sm:col-start-2">
            <span class="text-caption text-pin-silver">다음 글 →</span>
            <p class="mt-1 text-caption-bold leading-snug text-pin-plum group-hover:text-pin-red">{newerPost.data.title}</p>
          </a>
        ) : <span></span>}
      </nav>
    )}
  </article>

  <style is:global>
    /* Code blocks: dark surface, matches design system's pin-dark token */
    .post-article pre {
      position: relative;
      background: #33332e !important;
      border-radius: 12px;
      padding: 18px 20px !important;
      font-size: 13px;
      line-height: 1.6;
      overflow-x: auto;
    }
    .post-article pre code {
      background: transparent;
      font-family: ui-monospace, Menlo, monospace;
    }
    .post-article :not(pre) > code {
      background: #e5e5e0;
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 0.9em;
    }
    .post-copy-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: #211922;
      color: #f6f6f3;
      border: none;
      border-radius: 8px;
      padding: 6px 9px;
      font-size: 11px;
      font-family: inherit;
      font-weight: 700;
      cursor: pointer;
      opacity: 0.85;
    }
    .post-copy-btn:hover { opacity: 1; background: #33332e; }
    .post-toc a[data-active="true"] { color: #e60023; font-weight: 700; }
    .mermaid-diagram {
      display: flex;
      justify-content: center;
      margin: 1.5rem 0;
      overflow-x: auto;
    }
    .mermaid-diagram svg { max-width: 100%; height: auto; }
    /* KaTeX: let long display equations scroll instead of overflowing */
    .post-article .katex-display { overflow-x: auto; overflow-y: hidden; padding: 4px 0; }
  </style>

  <script>
    // Delete Post — same two paths as saving in /new:
    //  * localhost: the dev server's /api/delete removes the file, commits and
    //    pushes in the background.
    //  * live site: delete posts/<slug>.md via the GitHub Contents API using
    //    the fine-grained PAT stored in localStorage by /new's ⚙️ settings.
    const GH_OWNER = 'Mm-767';
    const GH_REPO = 'Mm-767.github.io';
    const GH_BRANCH = 'main';

    const deleteBtn = document.getElementById('delete-post-btn');
    deleteBtn?.addEventListener('click', async () => {
      const { slug, title } = deleteBtn.dataset;
      if (!confirm('"' + title + '" 포스트를 삭제할까요? 저장소에서도 삭제(커밋)됩니다.')) return;

      const originalHtml = deleteBtn.innerHTML;
      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting…';
      const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
      try {
        if (isLocal) {
          const res = await fetch('/api/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug }),
          });
          if (!res.ok) throw new Error('Delete endpoint returned ' + res.status);
          const data = await res.json();
          if (data.gitError) {
            alert('파일은 삭제됐지만 git 커밋에 실패했습니다: ' + data.gitError +
              '\n직접 git add/commit/push로 반영해 주세요.');
          }
          location.href = '/';
          return;
        }

        const token = localStorage.getItem('gh_pat');
        if (!token) {
          alert('삭제하려면 GitHub 토큰이 필요합니다 — /new 페이지의 ⚙️ GitHub 게시 설정에서 토큰을 저장한 뒤 다시 시도하세요.');
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = originalHtml;
          return;
        }
        const headers = {
          Authorization: 'Bearer ' + token,
          Accept: 'application/vnd.github+json',
          'X-GitHub-Api-Version': '2022-11-28',
        };
        const encPath = ['posts', slug + '.md'].map(encodeURIComponent).join('/');
        const url = 'https://api.github.com/repos/' + GH_OWNER + '/' + GH_REPO + '/contents/' + encPath;
        const lookup = await fetch(url + '?ref=' + GH_BRANCH, { headers });
        if (!lookup.ok) throw new Error('저장소에서 파일을 찾지 못했습니다 (HTTP ' + lookup.status + ').');
        const { sha } = await lookup.json();
        const del = await fetch(url, {
          method: 'DELETE',
          headers: { ...headers, 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: 'Delete post: ' + title, sha, branch: GH_BRANCH }),
        });
        if (!del.ok) throw new Error('삭제 커밋에 실패했습니다 (HTTP ' + del.status + ').');
        alert('🗑️ 삭제 완료! GitHub Pages 빌드 후(보통 1~3분) 사이트에서 사라집니다.');
        location.href = '/';
      } catch (err) {
        alert(err instanceof Error ? err.message : '삭제에 실패했습니다.');
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = originalHtml;
      }
    });
  </script>

  <script>
    // Copy-to-clipboard button on every rendered code block.
    const COPY_ICON = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>';
    const CHECK_ICON = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';

    document.querySelectorAll('.post-article pre:not([data-language="mermaid"])').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'post-copy-btn';
      btn.type = 'button';
      btn.innerHTML = COPY_ICON + '<span>Copy</span>';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        await navigator.clipboard.writeText((code || pre).innerText);
        btn.innerHTML = CHECK_ICON + '<span>Copied</span>';
        setTimeout(() => { btn.innerHTML = COPY_ICON + '<span>Copy</span>'; }, 1500);
      });
      pre.appendChild(btn);
    });

    // Scroll-spy: highlight the active ToC entry.
    const links = Array.from(document.querySelectorAll('[data-toc-link]'));
    const targets = links
      .map((l) => document.getElementById(l.getAttribute('data-toc-link') || ''))
      .filter(Boolean);
    if (targets.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const link = links.find((l) => l.getAttribute('data-toc-link') === entry.target.id);
            if (link && entry.isIntersecting) {
              links.forEach((l) => l.removeAttribute('data-active'));
              link.setAttribute('data-active', 'true');
            }
          });
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      targets.forEach((t) => observer.observe(t));
    }
  </script>

  <script>
    // Render ```mermaid code blocks as diagrams (client-side, static-host friendly).
    const mermaidBlocks = document.querySelectorAll('.post-article pre[data-language="mermaid"]');
    if (mermaidBlocks.length) {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      let i = 0;
      for (const pre of mermaidBlocks) {
        const code = pre.querySelector('code')?.textContent ?? '';
        try {
          const { svg } = await mermaid.render('mermaid-diagram-' + i++, code);
          const container = document.createElement('div');
          container.className = 'mermaid-diagram';
          container.innerHTML = svg;
          pre.replaceWith(container);
        } catch {
          // Leave the code block as-is if the diagram fails to parse.
        }
      }
    }
  </script>
</BaseLayout>
